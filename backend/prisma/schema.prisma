generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Checklist {
  id        Int     @id @default(autoincrement())
  pregunta  String
  cumple    Boolean @default(false)
  empresaId Int

  evidencias Evidencia[]
}

model Evidencia {
  id          Int    @id @default(autoincrement())
  archivo     String
  observacion String?

  checklistId Int
  checklist   Checklist @relation(fields: [checklistId], references: [id])

  empresaId Int
}